# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/

# PyInstaller output
dist/
build/*
!build/*.spec
!build/*.ps1
*.spec.bak

# Tests
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# PyInstaller generated
build/version_info.txt

# Build leftovers (locked exe rename)
*.exe.stale

# Downloaded fonts (use scripts/setup_fonts.ps1)
resources/fonts/*.ttf
resources/fonts/*.otf
!resources/fonts/.gitkeep

# Installer output (dist/ already ignored; explicit for clarity)
*.Setup.exe

# IDE / Editor
.idea/
.vscode/
.cursor/
*.swp

# Env files
.env
.env.*

# App data (local dev)
*.db
*.log

# Bundled binaries (downloaded at build time)
resources/bin/ffmpeg.exe
resources/bin/yt-dlp.exe

# OS
Thumbs.db
Desktop.ini

# Release artifacts
*.zip
